# ============================================================
# CoreAI API — Environment Variables Template
# Copy this file to .env for local development.
# Set these as Environment Variables in Vercel dashboard for production.
# NEVER commit the real .env file — it is in .gitignore.
# ============================================================

# --- Database ---
# Local SQLite (development only):
DATABASE_URL=sqlite+aiosqlite:///./coreai.db
# Production PostgreSQL (e.g., Neon, Supabase, Railway):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# --- Cache ---
# Local Redis:
REDIS_URL=redis://localhost:6379/0
# Production Redis (e.g., Upstash):
# REDIS_URL=rediss://:password@host:6380

# --- Security ---
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# --- Application ---
ENVIRONMENT=production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["https://your-frontend.vercel.app"]

# --- AI ---
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
AI_MODEL=gemini-2.0-flash

# --- Email (optional) ---
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@coreai.com
MAIL_FROM_NAME=CoreAI
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
