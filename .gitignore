# ============================================================
# CoreAI — Root .gitignore
# ============================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Build outputs ---
.next/
dist/
build/
out/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Environment files (NEVER commit real secrets) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example and .env.production (template only) committed
!.env.example
!.env.production

# --- SQLite (local dev DB — use Postgres in production) ---
*.db
*.sqlite
*.sqlite3

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Vercel ---
.vercel/

# --- Testing ---
coverage/
.coverage
htmlcov/

# --- Temp / scratch ---
scratch/
*.tmp
*.temp
test_*.py
check_*.py
test.json

# --- Docker ---
# Keep docker-compose.yml committed for local dev reference
